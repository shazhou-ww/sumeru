{
  "name": "@sumeru/sumeru-session",
  "description": "Unified Sumeru adapter session entrypoint with CLI auto-detection",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "sumeru-session": "./dist/main.js"
  },
  "exports": {
