      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "license": "MIT",
  "dependencies": {
    "@sumeru/adapter-claude-code": "workspace:*",
    "@sumeru/adapter-codex": "workspace:*",
    "@sumeru/adapter-core": "workspace:*",
    "@sumeru/adapter-cursor-agent": "workspace:*",
    "@sumeru/adapter-hermes": "workspace:*",
    "@sumeru/core": "workspace:*",
    "@sumeru/sarsapa": "workspace:*"
  },
  "scripts": {
    "test:ci": "npx vitest run"
  }
