# Sumeru adapter credentials — EXAMPLE / TEMPLATE (Docker mode)
#
# CLI-based adapters (claude-code / codex / cursor-agent) need external auth
# that is injected into the container at run time. docker-compose.yaml reads
# this file via `env_file: { path: ./sumeru.env, required: false }`.
#
# SETUP (only if you run an adapter that needs external auth):
#   1. cp sumeru.env.example sumeru.env
#   2. chmod 600 sumeru.env          # owner-read-only, keep secrets safe
#   3. fill in the real values below
#   4. docker compose -p <name> up -d --build
#
# NOTES
#   - This file holds SECRETS. Never commit sumeru.env to git.
#   - Only sumeru.env.example (placeholders, no secrets) lives in the repo.
#   - Nodes that only use the hermes adapter can skip this file entirely
#     (env_file is marked required: false, so a missing file is not fatal).
#   - env-file format: KEY=value, one per line, NO `export`, NO quotes
#     unless the value literally contains them.

# claude-code adapter (Anthropic-compatible). Point ANTHROPIC_BASE_URL at your
# proxy or leave it at the public Anthropic API default.
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=
