# Sumeru adapter credentials — EXAMPLE / TEMPLATE
#
# CLI-based adapters need auth that does NOT survive into a systemd user
# service's environment (systemd does not inherit the login shell). This file
# supplies it via the unit's `EnvironmentFile=` directive.
#
# SETUP (per node, only if you run an adapter that needs external auth):
#   1. cp deploy/sumeru.env.example ~/.config/sumeru/env
#   2. chmod 600 ~/.config/sumeru/env        # owner-read-only, keep secrets safe
#   3. fill in the real values below
#   4. systemctl --user daemon-reload && systemctl --user restart sumeru
#
# NOTES
#   - This file holds SECRETS. Never commit ~/.config/sumeru/env to git.
#   - Only deploy/sumeru.env.example (placeholders, no secrets) lives in the repo.
#   - Nodes that only use the hermes adapter can skip this file entirely
#     (the unit marks EnvironmentFile optional with a leading "-").
#   - systemd env-file format: KEY=value, one per line, NO `export`, NO quotes
#     unless the value literally contains them.

# claude-code adapter (Anthropic-compatible). On our nodes this points at the
# local copilot proxy rather than the public Anthropic API.
ANTHROPIC_API_KEY=sk-replace-with-your-key
ANTHROPIC_BASE_URL=http://127.0.0.1:4141
